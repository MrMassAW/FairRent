{
  "name": "fairrent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch --include \"src/lib/**/*.ts\" --include \"src/types/**/*.ts\" server/index.ts",
    "dev:full": "concurrently -k \"npm run dev\" \"npm run dev:server\"",
    "dev:pair": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-side-by-side.ps1",
    "build": "tsc -b && vite build",
    "icons:pwa": "node scripts/generate-pwa-icons.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "data:weekly-update": "tsx scripts/weekly-update.ts",
    "data:cmhc-rms": "tsx scripts/cmhc-rms-ingest.ts",
    "data:cmhc-rms-merge": "tsx scripts/cmhc-rms-merge.ts",
    "data:rent-prices": "tsx scripts/rent-prices-pull.ts",
    "utility:ingest": "tsx scripts/utility-ingest.ts",
    "verify:sources": "tsx scripts/verify-sources.ts",
    "data:canada-geo": "tsx scripts/gen-canada-municipalities.ts",
    "data:canada-places": "tsx scripts/gen-canada-places.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.4.19",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.9"
  }
}
