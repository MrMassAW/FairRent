# FairRent listing agent API (server-side — never commit real keys)
LISTING_AGENT_PORT=8787

# Comma-separated extra browser origins allowed to call the listing agent API (CORS).
# Always includes localhost / 127.0.0.1 dev URLs, https://localhost, capacitor://localhost, and http://localhost (Capacitor WebViews).
# Add your deployed site origin(s), e.g. https://fairrent.example.com
# Use * only for local debugging — never in production.
# LISTING_AGENT_CORS_ORIGINS=https://fairrent.example.com

# Preferred: Google Gemini (AI Studio / Gemini API key). When GEMINI_API_KEY or GOOGLE_API_KEY is set, the server uses Gemini.
GEMINI_API_KEY=

# Optional: force provider — gemini | openai | auto (default: auto prefers Gemini when the key above is set).
# LLM_PROVIDER=gemini

# Default: Gemini 3 Flash. For Gemini 3.1 Flash-Lite, use gemini-3.1-flash-lite-preview (see Google model docs).
GEMINI_MODEL=gemini-3-flash-preview

# Vite: listing agent API base URL (must be JSON API, not the Vite dev server).
# Local: http://localhost:8787 with npm run dev:server
# Production / Capacitor: HTTPS URL where this API is deployed; must be listed in LISTING_AGENT_CORS_ORIGINS (or use * only for tests).
# Also serves GET /geo/provinces and GET /geo/cities for the calculator municipality list.
VITE_LISTING_AGENT_URL=http://localhost:8787

# Optional: override geo API only (defaults to VITE_LISTING_AGENT_URL).
# VITE_GEO_API_URL=http://localhost:8787

# Vite: admin / data API (weekly refresh, etc.). Defaults to http://localhost:8000 if unset.
# VITE_API_BASE_URL=http://localhost:8000

# PWA: deploy the built site over HTTPS so the service worker can register. Local dev may omit the SW.

# Optional: OpenEI URDB (npm run utility:ingest — tariff sample rows when set)
# OPENEI_API_KEY=
